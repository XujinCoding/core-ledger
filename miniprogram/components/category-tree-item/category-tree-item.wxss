/**
 * 分类树项组件样式
 */

.category-item {
  border-bottom: 1px solid #f0f0f0;
  transition: background-color 0.2s ease;
}

.category-item:active {
  background-color: #f5f5f5;
}

.category-item--level-0 {
  background-color: #ffffff;
}

.category-item--level-1 {
  background-color: #fafafa;
}

.category-item--level-2 {
  background-color: #f5f5f5;
}

.category-item__header {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx 16rpx 0;
  gap: 12rpx;
}

.category-item__expand {
  width: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.expand-icon {
  font-size: 20rpx;
  color: #999;
  transition: transform 0.2s ease;
  display: inline-block;
}

.expand-icon.expanded {
  transform: rotate(90deg);
}

.expand-icon--empty {
  width: 20rpx;
  display: inline-block;
}

.category-item__info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-item__name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.category-item__count {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.category-item__action {
  font-size: 32rpx;
  color: #999;
  padding: 0 8rpx;
}
