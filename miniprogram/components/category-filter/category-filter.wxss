/**
 * 分类筛选组件样式
 */

.category-filter {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
}

.category-filter__mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  animation: fade-in 0.3s ease;
}

.category-filter__panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slide-up 0.3s ease;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.category-filter__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx;
  border-bottom: 1px solid #f0f0f0;
}

.category-filter__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.category-filter__close {
  font-size: 48rpx;
  font-weight: 300;
  color: #999999;
  line-height: 1;
  padding: 0 8rpx;
  cursor: pointer;
}

.category-filter__content {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0;
}

.category-option {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx 16rpx 0;
  transition: background-color 0.2s;
  cursor: pointer;
}

.category-option:active {
  background-color: #f8f8f8;
}

.category-option--active {
  background-color: #f0faf5;
}

.category-option__expand {
  width: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.expand-icon {
  font-size: 20rpx;
  color: #999;
  transition: transform 0.2s ease;
  display: inline-block;
}

.expand-icon.expanded {
  transform: rotate(90deg);
}

.expand-icon--empty {
  width: 20rpx;
  display: inline-block;
}

.category-option__name {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.category-option--active .category-option__name {
  color: #07c160;
  font-weight: 500;
}

.category-option__check {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
  line-height: 1;
  flex-shrink: 0;
}

.category-filter__footer {
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #f0f0f0;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.category-filter__btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.category-filter__btn::after {
  border: none;
}

.category-filter__btn--reset {
  background-color: #f5f5f5;
  color: #666666;
  border: 1px solid #e8e8e8;
}

.category-filter__btn--reset:active {
  background-color: #e8e8e8;
}

.category-filter__btn--confirm {
  background-color: #07c160;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

.category-filter__btn--confirm:active {
  background-color: #06ad56;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}
