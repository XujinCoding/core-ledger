/**
 * 空状态组件样式
 */

.empty-state {
  text-align: center;
  padding: 160rpx 24rpx;
}

.empty-state__icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.empty-state__text {
  font-size: var(--font-md);
  color: var(--text-secondary);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.empty-state__action {
  margin-top: 32rpx;
}

.empty-state__button {
  padding: 20rpx 48rpx;
  background-color: var(--color-primary);
  color: var(--bg-white);
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.empty-state__button::after {
  border: none;
}
