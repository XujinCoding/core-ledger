<!--
  地址选择器组件
  支持省市区镇村5级懒加载选择
-->
<view class="address-picker" wx:if="{{visible}}">
  <view class="address-picker__mask" bindtap="handleClose"></view>
  
  <view class="address-picker__content">
    <!-- 标题栏 -->
    <view class="address-picker__header">
      <view class="address-picker__title">选择地址</view>
      <view class="address-picker__close" bindtap="handleClose">✕</view>
    </view>

    <!-- 地址路径导航 -->
    <view class="address-picker__breadcrumb" wx:if="{{selectedPath.length > 0}}">
      <view 
        wx:for="{{selectedPath}}" 
        wx:key="id"
        class="breadcrumb-item"
        bindtap="handleBreadcrumbClick"
        data-index="{{index}}"
      >
        {{item.name}}
        <text class="breadcrumb-arrow" wx:if="{{index < selectedPath.length - 1}}">›</text>
      </view>
    </view>

    <!-- 地址列表 -->
    <scroll-view class="address-picker__list" scroll-y>
      <view wx:if="{{loading}}" class="address-picker__loading">
        <text>加载中...</text>
      </view>

      <view wx:elif="{{currentList.length === 0}}" class="address-picker__empty">
        <text>暂无数据</text>
      </view>

      <view wx:else>
        <view 
          wx:for="{{currentList}}" 
          wx:key="id"
          class="address-item {{selectedId === item.id ? 'selected' : ''}}"
          bindtap="handleSelectAddress"
          data-address="{{item}}"
        >
          <view class="address-item__name">{{item.name}}</view>
          <view class="address-item__icon">
            <text wx:if="{{selectedId === item.id}}">✓</text>
            <text wx:elif="{{item.level < 5}}">›</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="address-picker__footer">
      <view class="address-picker__tip" wx:if="{{!canConfirm}}">
        <text>请至少选择到区县级</text>
      </view>
      <button 
        class="btn-cancel" 
        bindtap="handleClose"
      >取消</button>
      <button 
        class="btn-confirm {{canConfirm ? '' : 'disabled'}}" 
        bindtap="handleConfirm"
        disabled="{{!canConfirm}}"
      >确定</button>
    </view>
  </view>
</view>
