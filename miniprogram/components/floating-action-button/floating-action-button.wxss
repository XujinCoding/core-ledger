/**
 * 浮动操作按钮样式
 */

.fab-container {
  position: fixed;
  right: 30rpx;
  bottom: 100rpx;
  z-index: 999;
}

.fab-button {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--bg-white);
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.fab-icon {
  width: 48rpx;
  height: 48rpx;
}

.fab-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
