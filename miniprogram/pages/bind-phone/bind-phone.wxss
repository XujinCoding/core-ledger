/* pages/bind-phone/bind-phone.wxss */
.bind-phone-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 120rpx 60rpx 60rpx;
  box-sizing: border-box;
}

/* 顶部提示 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.header .icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
}

/* 微信一键绑定 */
.wechat-bind-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-bind-btn::after {
  border: none;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

/* 分割线 */
.divider {
  display: flex;
  align-items: center;
  margin: 48rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #e5e5e5;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  height: 96rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 32rpx;
}

.form-label {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.icon-small {
  width: 100%;
  height: 100%;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}

.send-code-btn {
  width: 180rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 24rpx;
  border: none;
  padding: 0;
  line-height: 64rpx;
}

.send-code-btn::after {
  border: none;
}

.send-code-btn.disabled {
  background: #e5e5e5;
  color: #999999;
}

/* 绑定按钮 */
.bind-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.bind-btn::after {
  border: none;
}

/* 提示文本 */
.tips {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #999999;
}

/* 底部操作 */
.footer {
  display: flex;
  justify-content: center;
  margin-top: 48rpx;
}

.back-link {
  font-size: 28rpx;
  color: #ffffff;
  text-decoration: underline;
}

/* 用户信息展示 */
.user-info-display {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  backdrop-filter: blur(10px);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.user-nickname {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
}
