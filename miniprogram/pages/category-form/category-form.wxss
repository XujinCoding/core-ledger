/**
 * 商品分类表单页面样式
 */
@import '../../styles/common.wxss';

.page-container {
  min-height: 100vh;
  background-color: var(--bg-gray);
  padding-bottom: 120rpx;
}

/* 表单容器 */
.form-container {
  padding: 24rpx;
}

/* 表单分组 */
.form-section {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.form-section__title {
  font-size: 28rpx;
  font-weight: var(--font-medium);
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid var(--divider-color);
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid var(--divider-color);
}

.form-item:last-child {
  border-bottom: none;
}

.form-item--textarea {
  align-items: flex-start;
}

.form-item--readonly {
  background-color: var(--bg-gray);
  padding: 24rpx;
  border-radius: var(--radius-sm);
  border: none;
}

.form-item__label {
  flex-shrink: 0;
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.form-item--required .form-item__label::before {
  content: '* ';
  color: var(--color-danger);
}

.form-item__input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-item__textarea {
  flex: 1;
  min-height: 120rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.form-item__value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 底部操作按钮 */
.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background-color: var(--bg-white);
  border-top: 1px solid var(--divider-color);
  z-index: 100;
}

.btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
  font-weight: var(--font-medium);
  border: none;
  line-height: 1;
}

.btn--cancel {
  background-color: var(--bg-gray);
  color: var(--text-primary);
}

.btn--primary {
  background-color: var(--color-primary);
  color: var(--bg-white);
}

.btn--primary[disabled] {
  background-color: var(--bg-gray);
  color: var(--text-secondary);
}
