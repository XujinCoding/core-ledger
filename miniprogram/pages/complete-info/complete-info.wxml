<!--pages/complete-info/complete-info.wxml-->
<view class="complete-info-page">
  <!-- 顶部提示 -->
  <view class="header">
    <image class="icon" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">完善个人信息</text>
    <text class="desc">设置你的昵称和头像</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 头像选择（放在最上面） -->
    <view class="form-item avatar-item" wx:if="{{canIUseChooseAvatar}}">
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image 
          class="avatar" 
          src="{{avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" 
          mode="aspectFill"
        ></image>
        <text class="avatar-tip">点击选择头像（可选）</text>
      </button>
    </view>

    <!-- 手机号输入（必填） -->
    <view class="form-item">
      <text class="form-label">手机号 <text class="required">*</text></text>
      <input 
        type="number"
        class="form-input" 
        placeholder="请输入手机号"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 昵称输入 -->
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input 
        type="text"
        class="form-input" 
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <!-- 完成按钮 -->
    <button 
      class="complete-btn" 
      bindtap="handleComplete"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      完成
    </button>

    <!-- 跳过按钮（放在最下方，小一点） -->
    <button 
      class="skip-btn" 
      bindtap="handleSkip"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      跳过
    </button>
  </view>
</view>
