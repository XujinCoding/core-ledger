<!--
  客户详情页面
  展示客户完整信息
-->
<view class="page-container" wx:if="{{!loading && customer}}">
  <!-- 客户头部 -->
  <view class="customer-header">
    <view class="customer-header__top">
      <view class="customer-header__info">
        <view class="customer-header__name">
          <text>{{customer.name}}</text>
          <text wx:if="{{customer.alias}}" class="customer-header__alias">({{customer.alias}})</text>
        </view>
        <view class="customer-header__type">
          <text class="type-tag {{customer.customerType === '1' ? 'active' : 'potential'}}">{{customer.customerTypeDesc}}</text>
        </view>
      </view>
      <view class="customer-header__action" bindtap="handleEdit">
        <text>✏️</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="info-section__title">基本信息</view>
    <view class="info-row">
      <view class="info-row__label">手机号</view>
      <view class="info-row__value">
        {{customer.phone}}
        <text class="info-row__action" bindtap="handleCall">📞</text>
      </view>
    </view>
    <view class="info-row" wx:if="{{customer.genderDesc}}">
      <view class="info-row__label">性别</view>
      <view class="info-row__value">{{customer.genderDesc}}</view>
    </view>
    <view class="info-row" wx:if="{{customer.age}}">
      <view class="info-row__label">年龄</view>
      <view class="info-row__value">{{customer.age}}岁</view>
    </view>
  </view>

  <!-- 地址信息 -->
  <view class="info-section">
    <view class="info-section__header">
      <view class="info-section__title">地址信息</view>
      <text class="info-section__action" bindtap="handleEditAddress">修改</text>
    </view>
    <view class="info-row" wx:if="{{customer.addressPath}}">
      <view class="info-row__label">所在地址</view>
      <view class="info-row__value"><text>{{customer.addressPath}}</text></view>
    </view>
    <view class="info-row" wx:if="{{customer.addressDetail}}">
      <view class="info-row__label">详细地址</view>
      <view class="info-row__value"><text>{{customer.addressDetail}}</text></view>
    </view>
  </view>

  <!-- 账单统计 -->
  <view class="info-section" wx:if="{{customer.ledgerSummary}}">
    <view class="info-section__title">账单统计</view>
    <view class="ledger-stats">
      <view class="stat-item" wx:if="{{customer.ledgerSummary.inProgressCount > 0}}">
        <view class="stat-item__label">进行中</view>
        <view class="stat-item__value">
          {{customer.ledgerSummary.inProgressCount}}笔
          <text class="stat-item__amount">¥{{customer.ledgerSummary.inProgressAmount}}</text>
        </view>
      </view>
      <view class="stat-item" wx:if="{{customer.ledgerSummary.partialCount > 0}}">
        <view class="stat-item__label">部分缴费</view>
        <view class="stat-item__value">
          {{customer.ledgerSummary.partialCount}}笔
          <text class="stat-item__amount">
            ¥{{customer.ledgerSummary.partialPaidAmount}}/¥{{customer.ledgerSummary.partialPaidAmount + customer.ledgerSummary.partialAmount}}
          </text>
        </view>
      </view>
      <view class="stat-item" wx:if="{{customer.ledgerSummary.creditCount > 0}}">
        <view class="stat-item__label">赊账</view>
        <view class="stat-item__value">
          {{customer.ledgerSummary.creditCount}}笔
          <text class="stat-item__amount">¥{{customer.ledgerSummary.creditAmount}}</text>
        </view>
      </view>
      <view class="stat-item" wx:if="{{customer.ledgerSummary.clearedCount > 0}}">
        <view class="stat-item__label">已结清</view>
        <view class="stat-item__value">{{customer.ledgerSummary.clearedCount}}笔</view>
      </view>
    </view>
  </view>

  <!-- 备注说明 -->
  <view class="info-section" wx:if="{{customer.memo}}">
    <view class="info-section__title">备注说明</view>
    <view class="memo-content">{{customer.memo}}</view>
  </view>

  <!-- 其他信息 -->
  <view class="info-section">
    <view class="info-section__title">其他信息</view>
    <view class="info-row">
      <view class="info-row__label">创建时间</view>
      <view class="info-row__value">{{customer.createInstant}}</view>
    </view>
    <view class="info-row">
      <view class="info-row__label">更新时间</view>
      <view class="info-row__value">{{customer.modifyInstant}}</view>
    </view>
  </view>

  <!-- 删除按钮 -->
  <view class="delete-section">
    <button class="btn-delete" bindtap="handleDelete">删除客户</button>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-state" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
