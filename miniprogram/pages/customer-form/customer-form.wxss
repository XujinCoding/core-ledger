/**
 * 客户表单页面样式
 */

.page-container {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 120rpx;
}

/* 表单区块 */
.form-section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-top: 16rpx solid #f7f8fa;
}

.form-section:first-child {
  border-top: none;
}

.form-section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
  padding-bottom: 16rpx;
}

/* 表单项 */
.form-item {
  padding: 16rpx 0;
}

.form-item:last-child {
  padding-bottom: 0;
}

.form-item__label {
  font-size: 28rpx;
  color: #646566;
  margin-bottom: 16rpx;
  display: block;
}

.form-item__label.required::before {
  content: '*';
  color: #ee0a24;
  margin-right: 4rpx;
}

.form-item__input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #323233;
}

.form-item__textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 24rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #323233;
}

.form-item__picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.form-item__picker .placeholder {
  color: #c8c9cc;
}

.form-item__picker .arrow {
  font-size: 40rpx;
  color: #c8c9cc;
  transform: rotate(90deg);
}

/* 单选按钮组 */
.radio-item {
  display: inline-flex;
  align-items: center;
  margin-right: 48rpx;
  font-size: 28rpx;
  color: #323233;
}

.radio-item radio {
  margin-right: 12rpx;
}

/* 操作按钮 */
.form-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-cancel,
.btn-submit {
  flex: 1;
  height: 88rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cancel {
  background: #f7f8fa;
  color: #646566;
}

.btn-submit {
  background: #07C160;
  color: #fff;
}

.btn-cancel::after,
.btn-submit::after {
  border: none;
}
