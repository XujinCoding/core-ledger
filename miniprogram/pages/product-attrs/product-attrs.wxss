/**
 * 商品属性配置页面样式
 */

.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  padding-bottom: 160rpx;
}

.content {
  flex: 1;
}

/* 商品信息 */
.product-info {
  background-color: #ffffff;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.product-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 属性列表 */
.attr-list {
  padding: 24rpx 0;
}

.attr-item {
  background-color: #ffffff;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.attr-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.attr-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.attr-delete {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 8rpx 16rpx;
}

.attr-row {
  margin-bottom: 24rpx;
}

.attr-row:last-child {
  margin-bottom: 0;
}

.attr-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4d4f;
  margin-right: 4rpx;
}

.attr-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.attr-values-container {
  width: 100%;
}

.attr-values {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.attr-value-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #f0faf5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
}

.attr-value-delete {
  font-size: 32rpx;
  color: #999999;
  line-height: 1;
}

.attr-value-add {
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border: 1px dashed #d9d9d9;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666666;
}

/* 添加属性按钮 */
.add-attr-btn {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  color: #07c160;
  border: 1px dashed #07c160;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 底部操作按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1px solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.footer-btn::after {
  border: none;
}

.footer-btn--cancel {
  background-color: #f5f5f5;
  color: #666666;
  border: 1px solid #e8e8e8;
}

.footer-btn--cancel:active {
  background-color: #e8e8e8;
}

.footer-btn--save {
  background-color: #07c160;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

.footer-btn--save:active {
  background-color: #06ad56;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  text-align: center;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn::after {
  border: none;
}

.modal-btn--cancel {
  background-color: #f5f5f5;
  color: #666666;
}

.modal-btn--confirm {
  background-color: #07c160;
  color: #ffffff;
}
