<!--
  账单页面（首页）
  设计风格：清新商务风（Fresh Business）
  布局：卡片列表 + FAB按钮
-->
<view class="page-container">
  <!-- 账单卡片列表 -->
  <view class="ledger-list" wx:if="{{ledgers.length > 0}}">
    <view
      class="ledger-card card"
      wx:for="{{ledgers}}"
      wx:key="id"
      bindtap="handleCardClick"
      data-id="{{item.id}}"
    >
      <!-- 左侧：客户信息 -->
      <view class="ledger-card__left">
        <view class="ledger-card__customer-name title-primary">
          {{item.customerName}}
        </view>
        <view class="ledger-card__customer-phone title-secondary">
          {{item.customerPhone}}
        </view>
      </view>

      <!-- 右侧：应收金额 -->
      <view class="ledger-card__right">
        <view class="ledger-card__amount amount-text">
          ¥{{item.remainingAmount.toFixed(2)}}
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{ledgers.length === 0 && !loading}}">
    <view class="empty-state__icon">📋</view>
    <view class="empty-state__text">暂无账单记录</view>
    <view class="empty-state__text text-secondary">点击右下角按钮创建账单</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- FAB 悬浮按钮 -->
  <view class="fab-button" bindtap="handleCreateLedger">
    <text class="fab-button__icon">+</text>
  </view>
</view>
