<!--
  商品管理页面
  Phase 1: 基础功能 - 商品分类 + 商品列表
-->
<view class="page-container">
  <!-- Tab切换栏 -->
  <view class="tab-bar">
    <view class="tab-bar__tabs">
      <view 
        class="tab-item {{activeTab === 0 ? 'tab-item--active' : ''}}"
        bindtap="handleTabChange"
        data-index="0"
      >
        <text>商品列表</text>
      </view>
      <view 
        class="tab-item {{activeTab === 1 ? 'tab-item--active' : ''}}"
        bindtap="handleTabChange"
        data-index="1"
      >
        <text>商品分类</text>
      </view>
    </view>
  </view>

  <!-- Tab 0: 商品列表 -->
  <view class="tab-content" wx:if="{{activeTab === 0}}">
    <!-- 搜索框 -->
    <view class="search-wrapper">
      <search-bar
        placeholder="搜索商品名称..."
        bind:search="handleSearch"
      />
      <view class="search-filter" bindtap="handleShowFilter">
        <text>筛选🎚</text>
      </view>
    </view>

    <!-- 筛选条件 -->
    <view class="filter-bar" wx:if="{{selectedCategoryId || selectedStatus}}">
      <view class="filter-tag" wx:if="{{selectedCategoryId}}">
        <text>{{selectedCategoryName}}</text>
        <text class="filter-tag__close" bindtap="handleClearCategoryFilter">×</text>
      </view>
      <view class="filter-tag" wx:if="{{selectedStatus}}">
        <text>{{selectedStatus === '1' ? '启用' : '禁用'}}</text>
        <text class="filter-tag__close" bindtap="handleClearStatusFilter">×</text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="product-list" wx:if="{{products.length > 0}}">
      <product-card
        wx:for="{{products}}"
        wx:key="id"
        item="{{item}}"
        bind:click="handleItemClick"
        bind:action="handleProductAction"
      />
    </view>

    <!-- 空状态 -->
    <empty-state
      wx:if="{{products.length === 0 && !loading}}"
      icon="📦"
      text="暂无商品"
      buttonText="新增商品"
      bind:action="handleAddProduct"
    />

    <!-- 加载状态 -->
    <loading-spinner wx:if="{{loading}}" text="加载中..." />
  </view>

  <!-- Tab 1: 商品分类管理 -->
  <view class="tab-content" wx:if="{{activeTab === 1}}">
    <!-- 分类树列表 -->
    <view class="category-list" wx:if="{{categories.length > 0}}">
      <category-tree-item
        wx:for="{{categories}}"
        wx:key="id"
        item="{{item}}"
        level="0"
        bind:toggle="handleCategoryToggle"
        bind:action="handleCategoryAction"
      />
    </view>

    <!-- 空状态 -->
    <empty-state
      wx:if="{{categories.length === 0 && !categoryLoading}}"
      icon="📂"
      text="暂无分类"
      buttonText="新增顶级分类"
      bind:action="handleAddCategory"
    />

    <!-- 加载状态 -->
    <loading-spinner wx:if="{{categoryLoading}}" text="加载中..." />
  </view>

  <!-- 右下角浮动按钮 -->
  <view class="fab" bindtap="handleFabClick">
    <text class="fab__icon">+</text>
  </view>

  <!-- 分类筛选面板 -->
  <category-filter
    show="{{showFilter}}"
    categories="{{categories}}"
    selectedId="{{selectedCategoryId}}"
    bind:confirm="handleFilterConfirm"
    bind:close="handleFilterClose"
  />
</view>
