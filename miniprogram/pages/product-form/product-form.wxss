/**
 * 商品表单页面样式
 */

.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  padding-bottom: 160rpx;
}

.form-container {
  flex: 1;
  padding: 0;
}

/* 表单区块 */
.form-section {
  background-color: #ffffff;
  margin-top: 24rpx;
}

.form-section__title {
  padding: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  border-bottom: 1px solid #f0f0f0;
}

/* 表单项 */
.form-item {
  padding: 28rpx 32rpx;
  border-bottom: 1px solid #f0f0f0;
  display: flex;
  align-items: center;
  background-color: #ffffff;
  transition: background-color 0.2s;
}

.form-item:active {
  background-color: #f8f8f8;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item--textarea {
  align-items: flex-start;
  flex-direction: column;
}

.form-item__label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333333;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.form-item--textarea .form-item__label {
  width: 100%;
  margin-bottom: 16rpx;
}

.form-item__required {
  color: #ff4d4f;
  margin-right: 4rpx;
  font-size: 28rpx;
}

.form-item__input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.form-item__input::placeholder {
  color: #bfbfbf;
}

.form-item__input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.form-item__prefix {
  font-size: 28rpx;
  color: #333333;
  margin-right: 8rpx;
  font-weight: 500;
}

.form-item__textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  padding: 16rpx 0;
}

.form-item__textarea::placeholder {
  color: #bfbfbf;
}

.form-item__picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
  color: #333333;
}

.form-item__placeholder {
  color: #bfbfbf;
}

.form-item__arrow {
  font-size: 36rpx;
  color: #bfbfbf;
  margin-left: 12rpx;
  font-weight: 300;
  transform: rotate(-90deg);
}

/* 底部操作按钮 */
.form-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1px solid #f0f0f0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.form-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.form-btn::after {
  border: none;
}

.form-btn--cancel {
  background-color: #f5f5f5;
  color: #666666;
  border: 1px solid #e8e8e8;
}

.form-btn--cancel:active {
  background-color: #e8e8e8;
}

.form-btn--submit {
  background-color: #07c160;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

.form-btn--submit:active {
  background-color: #06ad56;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}
