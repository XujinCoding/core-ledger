<!--
  客户管理页面
  使用组件化设计
-->
<view class="page-container">
  <!-- 搜索和筛选区域 -->
  <view class="search-filter-container">
    <!-- 搜索框块 -->
    <view class="search-block">
      <!-- 搜索类型下拉 -->
      <picker 
        class="search-type-picker"
        mode="selector"
        range="{{searchTypes}}"
        range-key="label"
        value="{{searchTypeIndex}}"
        bindchange="handleSearchTypeChange"
      >
        <view class="search-type-picker__value">
          <text>{{searchTypes[searchTypeIndex].label}}</text>
          <text class="search-type-picker__arrow">▼</text>
        </view>
      </picker>

      <!-- 搜索框 -->
      <view class="search-input-wrapper">
        <search-bar 
          placeholder="{{searchTypes[searchTypeIndex].placeholder}}"
          bind:search="handleSearch"
        />
      </view>
    </view>

    <!-- 筛选按钮块 -->
    <view class="filter-block">
      <view class="filter-btn" bindtap="handleAddressFilter">
        <text class="filter-btn__icon">📍</text>
      </view>
    </view>
  </view>

  <!-- 筛选条件标签 -->
  <view class="filter-tags-container" wx:if="{{filterAddressId}}">
    <view class="filter-tag">
      <text class="filter-tag__label">地区：</text>
      <text class="filter-tag__value">{{filterAddressLastName}}</text>
      <text class="filter-tag__close" bindtap="handleClearFilter">✕</text>
    </view>
  </view>

  <!-- 客户列表 -->
  <scroll-view 
    wx:if="{{customers.length > 0}}"
    class="customer-list-container"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    bindscrolltolower="onReachBottom"
  >
    <view class="customer-list">
      <customer-card
        wx:for="{{customers}}"
        wx:key="id"
        customer="{{item}}"
        bind:click="handleCustomerClick"
        bind:action="handleCustomerAction"
      />
    </view>

    <!-- 加载更多提示 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text>加载更多...</text>
    </view>

    <!-- 到底了 -->
    <view class="no-more" wx:if="{{!hasMore}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{customers.length === 0 && !loading}}"
    icon="👥"
    text="暂无客户数据"
  />

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading && page === 0}}">
    <text>加载中...</text>
  </view>

  <!-- 浮动操作按钮 -->
  <floating-action-button bind:click="handleAdd" />

  <!-- 地址选择器（用于筛选） -->
  <address-picker
    visible="{{showAddressPicker}}"
    addressId="{{filterAddressId}}"
    bind:confirm="handleAddressFilterConfirm"
    bind:close="handleAddressFilterClose"
  />
</view>
