/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 60rpx;
  box-sizing: border-box;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.1);
}

/* 微信登录 */
.wechat-login {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.tips {
  margin-top: 32rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #999999;
}

/* 密码登录 */
.password-login {
  width: 100%;
}

.form-item {
  display: flex;
  align-items: center;
  height: 96rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 32rpx;
}

.form-label {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.icon {
  width: 100%;
  height: 100%;
}

.form-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}

.form-suffix {
  width: 48rpx;
  height: 48rpx;
  margin-left: 24rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-top: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.login-btn::after {
  border: none;
}

.forgot-password {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
}

/* 切换登录方式（固定在底部） */
.switch-login-bottom {
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding: 0 60rpx;
}

.switch-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border: none;
}

.switch-btn::after {
  border: none;
}

.switch-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.switch-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.link {
  color: #667eea;
  text-decoration: none;
}

/* 用户信息选择区域 */
.user-info-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像选择 */
.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  padding: 0;
  background: transparent;
  border: none;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
  display: block;
}

.avatar-tip {
  position: absolute;
  bottom: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: #999999;
  white-space: nowrap;
}

/* 昵称输入 */
.nickname-wrapper {
  width: 100%;
  display: flex;
  align-items: center;
  height: 96rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 48rpx;
  margin-top: 32rpx;
}

.nickname-label {
  font-size: 28rpx;
  color: #333333;
  margin-right: 24rpx;
  min-width: 80rpx;
}

.nickname-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333333;
}

/* 用户信息展示 */
.user-info-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.userinfo-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.userinfo-nickname {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

/* 错误提示 */
.error-tip {
  text-align: center;
  padding: 40rpx 0;
}

.error-tip text {
  font-size: 28rpx;
  color: #ff4444;
}
