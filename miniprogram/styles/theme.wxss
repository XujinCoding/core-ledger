/* 主题变量 */
page {
  /* 主题色 */
  --color-primary: #1989fa;
  --color-success: #07c160;
  --color-warning: #ff976a;
  --color-danger: #ee0a24;
  --color-info: #909399;

  /* 背景色 */
  --bg-page: #f5f5f5;
  --bg-white: #ffffff;
  --bg-gray: #f7f8fa;

  /* 文字色 */
  --text-primary: #323233;
  --text-secondary: #646566;
  --text-tertiary: #969799;
  --text-disabled: #c8c9cc;

  /* 边框色 */
  --border-color: #ebedf0;
  --border-light: #f2f3f5;

  /* 圆角 */
  --radius-sm: 4rpx;
  --radius-md: 8rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 字体大小 */
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
}
