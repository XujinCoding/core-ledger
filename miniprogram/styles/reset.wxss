/* 样式重置 */
page {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary, #323233);
  background-color: var(--bg-page, #f5f5f5);
}

/* 清除默认样式 */
view,
text,
button,
input,
textarea,
image {
  box-sizing: border-box;
}

/* 按钮重置 */
button {
  padding: 0;
  margin: 0;
  border: none;
  background: none;
  font-size: inherit;
  line-height: inherit;
}

button::after {
  border: none;
}

/* 输入框重置 */
input,
textarea {
  padding: 0;
  margin: 0;
  border: none;
  background: none;
  font-size: inherit;
  line-height: inherit;
}

/* 图片默认样式 */
image {
  display: block;
  width: 100%;
  height: auto;
}
